<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleName</key>
    <string>GoStudio Capture</string>
    <key>CFBundleDisplayName</key>
    <string>GoStudio Capture</string>
    <key>CFBundleIdentifier</key>
    <string>com.gostudio.capture</string>
    <key>CFBundleVersion</key>
    <string>1</string>
    <key>CFBundleShortVersionString</key>
    <string>0.1.0</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>CFBundleExecutable</key>
    <string>GoStudioCapture</string>
    <key>LSMinimumSystemVersion</key>
    <string>13.0</string>

    <!-- Không icon Dock, không cửa sổ thường trú: app dùng-một-lần -->
    <key>LSUIElement</key>
    <true/>

    <!-- Cần khi thu âm thanh micro (tùy chọn audio=mic|both) -->
    <key>NSMicrophoneUsageDescription</key>
    <string>Dùng để thu âm thanh micro khi quay màn hình.</string>

    <!-- Đăng ký scheme gostudio:// để web kích hoạt -->
    <key>CFBundleURLTypes</key>
    <array>
        <dict>
            <key>CFBundleURLName</key>
            <string>com.gostudio.capture</string>
            <key>CFBundleURLSchemes</key>
            <array>
                <string>gostudio</string>
            </array>
        </dict>
    </array>
</dict>
</plist>
